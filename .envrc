# Load the parent directory's .envrc first (direnv), so shared
# repo-group env (e.g. ~/proj/.envrc) applies before these per-repo overrides.
source_up

# Claude Code Telegrammer
export CCT_ALLOWED_USERS="8379369979"
export CCT_AGENT_ID="scitex-cards"
# NOTE: the token-pool variable keeps its historical _TODO slot name — that is
# a secrets-pool key, not a package name, and renaming it means rotating the
# fleet's bot tokens. Out of scope for the package rename.
export CCT_BOT_TOKEN="$CCT_BOT_TOKEN_TODO"

# SciTeX Cards
#
# THE STORE IS DELIBERATELY NOT DEFINED HERE. This file used to export
#
#   SCITEX_TODO_TASKS_YAML_SHARED="$HOME/.scitex/todo/tasks.yaml"
#
# at a path that no longer exists, and an explicit store path WINS the
# resolution chain — so direnv silently handed anyone in this repo a store
# that cannot be read or written. It presents as "the board is empty", never
# as an error. The identical shape caused an hours-long silent MCP write
# outage on 2026-07-19.
#
# Three reasons the store does not belong in .envrc at all (operator, same
# day: 「.envrc より spec.yaml で env vars 定義した方が良さそう」):
#
#   1. Containers never read it. direnv only fires when a HUMAN cd's in;
#      agents get their env from the sac spec. Defining it in both makes two
#      sources of truth that WILL drift — and did: the spec was corrected on
#      2026-07-19 while this file still named the dead YAML path.
#   2. The store is fleet-global; .envrc is per-repo. Repo-scoped config for
#      a global resource is a category error.
#   3. This is a PUBLIC repo. A machine-local store path is not public
#      source (さいれぽじ).
#
# And the values were redundant anyway — measured with every store var
# unset, resolve_db_path() already returns ~/.scitex/cards/cards.db. Pinning
# the default buys nothing and adds a place to drift.
#
# Humans: rely on the default, or export SCITEX_CARDS_DB in your own shell
# profile. Agents: the sac spec is the single definition point.
export SCITEX_CARDS_AGENT_ID="scitex-cards"

