# PROPOSED (not yet wired): pin every test run to a scratch DB.
# On 2026-07-19 the suite twice rebuilt the LIVE fleet database from its own
# fixtures, because resolve_db_path(None) falls through to the user-canonical
# path when $SCITEX_CARDS_DB is unset. An in-code ownership guard is necessary
# but NOT sufficient — a test that never sets the var still points at the real
# board. The barrier belongs in the harness, where it cannot be reasoned away.
import os, tempfile, pathlib, pytest

@pytest.fixture(autouse=True, scope="session")
def _never_touch_the_live_store():
    scratch = pathlib.Path(tempfile.mkdtemp(prefix="scitex-cards-test-"))
    for var in ("SCITEX_CARDS_DB", "SCITEX_TODO_DB"):
        os.environ[var] = str(scratch / "cards.db")
    for var in ("SCITEX_CARDS_TASKS_YAML_SHARED", "SCITEX_TODO_TASKS_YAML_SHARED"):
        os.environ[var] = str(scratch / "tasks.yaml")
    yield
