# Load the parent directory's .envrc first (direnv), so shared
# repo-group env (e.g. ~/proj/.envrc) applies before these per-repo overrides.
source_up

# Claude Code Telegrammer
export CCT_ALLOWED_USERS="8379369979"
export CCT_AGENT_ID="scitex-cards"
# NOTE: the token-pool variable keeps its historical _TODO slot name — that is
# a secrets-pool key, not a package name, and renaming it means rotating the
# fleet's bot tokens. Out of scope for the package rename.
export CCT_BOT_TOKEN="$CCT_BOT_TOKEN_TODO"

# SciTeX Cards
#
# The store is a SQLite DB, and has been since the 2026-07-16 cutover. This
# file previously exported:
#
#   SCITEX_TODO_TASKS_YAML_SHARED="$HOME/.scitex/todo/tasks.yaml"
#
# which pointed at a path that NO LONGER EXISTS. That is not a cosmetic rename
# miss: an explicit store path wins the resolution chain, so direnv silently
# handed anyone working in this repo a store that cannot be read or written.
# The same shape caused a real, silent MCP write outage on 2026-07-19 — writes
# were refused for hours and nothing surfaced it, because the failure looks
# like "no cards" rather than an error.
export SCITEX_CARDS_AGENT_ID="scitex-cards"
export SCITEX_CARDS_STORE_BACKEND="sqlite"
export SCITEX_CARDS_DB="$HOME/.scitex/cards/cards.db"

# Legacy aliases, honoured for one transition window by
# scitex_cards._env_compat. Kept so a stale tool that still reads the old
# names resolves to the SAME store rather than to a different one.
export SCITEX_TODO_AGENT_ID="$SCITEX_CARDS_AGENT_ID"
export SCITEX_TODO_STORE_BACKEND="$SCITEX_CARDS_STORE_BACKEND"
export SCITEX_TODO_DB="$SCITEX_CARDS_DB"

